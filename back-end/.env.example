# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# xAI Grok API
XAI_API_KEY=xai-xxxxx
GROK_MODEL=grok-2-latest

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF
TELEGRAM_CHAT_ID=123456789

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJxxxxx

# Google Gemini (free tier fallback)
GEMINI_API_KEY=AIzaSyXXXXX
GEMINI_MODEL=gemini-2.5-flash

# AI Provider order (comma-separated, first available wins)
SYNTHESIS_PROVIDERS=["claude", "gemini"]
SENTIMENT_PROVIDERS=["grok", "gemini"]

# FRED (Federal Reserve Economic Data)
FRED_API_KEY=xxxxx

# Auth
AUTH_ENABLED=true
DEBUG=false
JWT_SECRET_KEY=generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
OTP_EXPIRE_SECONDS=120
SESSION_TOKEN_EXPIRE_SECONDS=180

# CORS (JSON array of allowed origins)
# Brain Editor (separate secret for brain tokens)
BRAIN_TOKEN_SECRET=generate-with-openssl-rand-hex-32

CORS_ORIGINS=["http://localhost:3000"]

# Telegram Webhook Secret (set when registering webhook)
TELEGRAM_WEBHOOK_SECRET=
